{{ ansible_managed | comment }}
install cramfs /bin/true
install freevxfs /bin/true
install jffs2 /bin/true
install hfs /bin/true
install hfsplus /bin/true
install squashfs /bin/true
install udf /bin/true
# required for /boot/efi
# https://unix.stackexchange.com/questions/638038/boot-efi-failed-to-mount-due-to-unknown-file-system-vfat-centos-7-5
# install vfat /bin/true
# https://askubuntu.com/questions/719058/blk-update-request-i-o-error-dev-fd0-sector-0
blacklist floppy
# https://cisofy.com/lynis/controls/NETW-3200/
blacklist dccp
blacklist sctp
blacklist rds
blacklist tipc
# https://copy.fail/ CVE-2026-31431
install algif_aead /bin/false
# https://github.com/v12-security/pocs/tree/main/fragnesia#mitigation
install esp4 /bin/false
install esp6 /bin/false
install rxrpc /bin/false
# CVE-2026-46331 https://github.com/sgkdev/packet_edit_meme
install act_pedit /bin/false
